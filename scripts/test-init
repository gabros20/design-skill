#!/usr/bin/env bash
# Regression test for safe template rendering and optional publishing profiles.
set -euo pipefail

root="$(cd "$(dirname "$0")/.." && pwd)"
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

mkdir -p "$tmp/full" "$tmp/core"
tar -C "$root" --exclude=.git --exclude=node_modules --exclude=.vercel -cf - . | tar -C "$tmp/full" -xf -
tar -C "$root" --exclude=.git --exclude=node_modules --exclude=.vercel -cf - . | tar -C "$tmp/core" -xf -

(
  cd "$tmp/full"
  ./scripts/init sample "Design & Build" "Design / build & ship workflows" \
    "#336699" "#6699cc" 220 --site --video >/dev/null
)

critical=(
  "$tmp/full/skills/sample"
  "$tmp/full/.codex-plugin"
  "$tmp/full/evals"
  "$tmp/full/install.sh"
  "$tmp/full/CHANGELOG.md"
  "$tmp/full/AGENTS.md"
  "$tmp/full/CLAUDE.md"
)
if grep -R -nE '__SKILL(_[A-Z]+)?__|__REPO_NAME__|__ACCENT_(LIGHT|DARK|HUE)__|__YEAR__' "${critical[@]}"; then
  echo "test-init: unresolved token after punctuation-safe rendering" >&2
  exit 1
fi

grep -q '"name": "sample-skill"' "$tmp/full/.codex-plugin/plugin.json"
grep -q "Use \$sample" "$tmp/full/skills/sample/agents/openai.yaml"
[ -d "$tmp/full/site" ]
[ -d "$tmp/full/remotion" ]

(
  cd "$tmp/core"
  ./scripts/init sample "Core Skill" "Focused agent workflow guidance" \
    "#336699" "#6699cc" 220 >/dev/null
)
[ ! -e "$tmp/core/site" ]
[ ! -e "$tmp/core/remotion" ]
[ ! -e "$tmp/core/vercel.json" ]

echo "test-init: OK — punctuation-safe rendering and core/site/video profiles work"
